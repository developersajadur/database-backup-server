# PostgreSQL
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database
DB_USER=postgres
DB_PASSWORD=

# Admin credentials for restore (CREATE/DROP DATABASE — falls back to DB_USER/DB_PASSWORD)
DB_ADMIN_USER=postgres
DB_ADMIN_PASSWORD=

# Backup directory
BACKUP_DIR=/app/backups

# Rclone (base64-encoded rclone.conf — generate: base64 -i ~/.config/rclone/rclone.conf | tr -d '\n')
RCLONE_CONFIG_BASE64=
RCLONE_REMOTE=gdrive
RCLONE_FOLDER=DatabaseBackups

# SMTP Email Alerts (commented out — uncomment to enable)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your_app_password
ALERT_EMAIL=alerts@example.com

# Cron schedule (default: daily at 2 AM)
BACKUP_CRON_SCHEDULE=0 2 * * *

# App
NODE_ENV=production
LOG_LEVEL=info
