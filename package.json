{
  "name": "db-backup-server",
  "version": "1.0.0",
  "description": "Automated PostgreSQL backup server with Google Drive upload and email alerts",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "backup": "ts-node src/index.ts --now",
    "restore": "node dist/restore/restore.js",
    "restore:dev": "ts-node src/restore/restore.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "googleapis": "^137.1.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.14",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.15",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  }
}
